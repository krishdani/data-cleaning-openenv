# Data Cleaning OpenEnv Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED: OpenAI / LLM Configuration
# ============================================================================

# OpenAI API Key (or HF token if using Hugging Face)
HF_TOKEN=sk-proj-your-key-here

# OpenAI API Base URL (use for custom endpoints)
API_BASE_URL=https://api.openai.com/v1

# Model to use for inference
MODEL_NAME=gpt-4-turbo

# ============================================================================
# ENVIRONMENT API Configuration
# ============================================================================

# URL where the environment is running (for local testing)
ENV_API_URL=http://localhost:7860

# ============================================================================
# INFERENCE Configuration
# ============================================================================

# Task difficulty: easy, medium, or hard
TASK_NAME=hard

# Maximum number of steps for inference
MAX_STEPS=15

# Maximum possible total reward (for score normalization)
MAX_TOTAL_REWARD=15

# Score threshold for success (0.0 - 1.0)
SUCCESS_SCORE_THRESHOLD=0.7

# ============================================================================
# OPTIONAL: Application Settings
# ============================================================================

# Port for the FastAPI application
PORT=7860

# Host for the FastAPI application  
HOST=0.0.0.0

# Whether to run with auto-reload (dev mode)
RELOAD=false

# ============================================================================
# NOTES
# ============================================================================
# - HF_TOKEN: Get from https://huggingface.co/settings/tokens
# - API_BASE_URL: Leave default for OpenAI. Change if using custom endpoint
# - MODEL_NAME: Use gpt-4-turbo, gpt-4, gpt-3.5-turbo, or custom model name
# - ENV_API_URL: When running in Docker on HF Spaces, use the Space URL
# - TASK_NAME: Choose from "easy", "medium", "hard"
# ============================================================================
